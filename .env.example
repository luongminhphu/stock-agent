# stock-agent environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── Runtime ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | test | production

# ── Database ───────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./stock_agent.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stock_agent

# ── Discord ────────────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here

# Optional. Set để sync slash commands tức thì (guild-specific, ~vài giây).
# Không set = global sync (áp dụng khắp nơi nhưng mất ~1 giờ).
# Bắt buộc có trong dev/test để test slash commands nhanh.
# Lấy bằng cách: Discord → Server Settings → Widget → Server ID
# hoặc bật Developer Mode → chuột phải vào server → Copy Server ID.
DISCORD_GUILD_ID=                 # e.g. 1062281594464899100

# ── Perplexity AI ───────────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:8080

# ── Feature Flags ───────────────────────────────────────────────────────────────────────
MOCK_MARKET=false                 # Set true in dev to skip real market API calls

# ── Discord Channel Routing ────────────────────────────────────────────────────────────────────────────────
#
# Channel routing matrix:
#
#   MORNING_CHANNEL_ID          → AgendaSubscriber (daily agenda)
#                               → PostMortemSubscriber (fallback khi DECISION chưa set)
#                               → briefing scheduler (morning brief 08:30 ICT)
#
#   EOD_CHANNEL_ID              → briefing scheduler (end-of-day brief 15:05 ICT)
#
#   DISCORD_ALERT_CHANNEL_ID    → InvalidationSubscriber
#                               → PositionRiskSubscriber
#                               → TrendShiftSubscriber
#                               → StressTestSubscriber
#                               → ProactiveWatchSubscriber
#                               → ProactiveDiscoverySubscriber
#                               → TrendPredictionSubscriber
#                               → EvolutionSubscriber
#                               → IntelligenceEngineSubscriber
#                               Bỏ trống = tất cả alert subscribers bị disable
#                               (không fallback — tránh trộn alert vào briefing channel)
#
#   DISCORD_DECISION_CHANNEL_ID → PostMortemSubscriber (post-mortem / decision replay)
#                               Bỏ trống = fallback sang MORNING_CHANNEL_ID
#
MORNING_CHANNEL_ID=               # e.g. 123456789012345678  → 08:30 ICT weekdays
EOD_CHANNEL_ID=                   # e.g. 123456789012345679  → 15:05 ICT weekdays
DISCORD_ALERT_CHANNEL_ID=1501852597491863562  # cảnh báo quan trọng (xem routing matrix trên)
DISCORD_DECISION_CHANNEL_ID=      # post-mortem/decision replay (mặc định dùng MORNING_CHANNEL_ID)

# Discord user snowflake whose watchlist drives scheduled briefs.
# Typically your own Discord user ID or a dedicated service account.
SCHEDULER_USER_ID=                # e.g. 987654321098765432

# ── Single-owner mode ───────────────────────────────────────────────────────────────────
# App chỉ có 1 user. Set bằng Discord User ID của owner.
# Dùng lệnh /whoami trong Discord hoặc bật Developer Mode để lấy ID.
OWNER_USER_ID=                    # e.g. 1062281594464899102
